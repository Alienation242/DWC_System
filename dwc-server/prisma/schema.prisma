datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

// Raw telemetry from ESP32 Sensor Node
model TelemetryLog {
  id                Int      @id @default(autoincrement())
  timestamp         DateTime @default(now())
  rawPH             Float
  rawEC             Float
  realPH            Float    // calculated pH
  realEC            Float    // calculated EC
  isTankEmpty       Boolean
  isTankOverflowing Boolean
}

// Persistent cultivation cycle state
model SystemState {
  id               Int      @id @default(1)
  currentStrain    String   @default("auto_kush")      // key for recipe
  currentProfilePath String @default("./recipes/default.json")
  cycleStartDate   DateTime @default(now())
  currentDay       Int      @default(1)
  automationMode   String   @default("AUTOMATED")      // or "MANUAL_OVERRIDE"
  lastDoseTime     DateTime?
  sysVol           Float    @default(18.0)             // actual reservoir liters
}

// Every successful or blocked dose (watchdog uses this)
model DoseLog {
  id        Int      @id @default(autoincrement())
  timestamp DateTime @default(now())
  pumpName  String   // "pH_Down", "Micro", "Bloom", "CalMag", "Gro", "Finisher"
  ml        Float
  status    String   @default("SUCCESS") // "SUCCESS", "BLOCKED"
}

// Watchdog configuration per pump
model WatchdogConfig {
  id            Int      @id @default(autoincrement())
  pumpName      String   @unique
  dailyLimitMl  Float    @default(15.0)
  cooldownSecs  Int      @default(30)
  enabled       Boolean  @default(true)
  updatedAt     DateTime @updatedAt
}