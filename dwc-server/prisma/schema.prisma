datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

// Raw telemetry from ESP32 Sensor Node
model TelemetryLog {
  id                Int      @id @default(autoincrement())
  potId             String
  rawPH             Int
  rawEC             Int
  realPH            Float
  realEC            Float
  isTankEmpty       Boolean
  isTankOverflowing Boolean
  timestamp         DateTime @default(now())
}

// Persistent cultivation cycle state
model SystemState {
  id                Int      @id @default(1)
  currentStrain     String
  currentProfilePath String
  currentDay        Int
  automationMode    String
  sysVol            Float
}

// Every successful or blocked dose (watchdog uses this)
model DoseLog {
  id        Int      @id @default(autoincrement())
  pumpName  String
  ml        Float
  potId     String   @default("A")
  status    String
  timestamp DateTime @default(now())
}

// Watchdog configuration per pump
model WatchdogConfig {
  pumpName      String   @id
  dailyLimitMl  Float
  cooldownSecs  Int
  enabled       Boolean  @default(true)
  updatedAt     DateTime @updatedAt
}

model BatchState {
  id                Int      @id @default(autoincrement())
  active            Boolean  @default(false)
  batchType         String   // "DILUTION", "NUTRIENT", "PH_CORRECTION", "EMERGENCY_WATER"
  totalWaterMl      Float
  confirmedWaterMl  Float    @default(0)
  totalNutrients    String?  // JSON string (e.g., {"cal":0,"micro":0,...})
  confirmedNutrients String? // JSON string
  targetPot         String?  @default("A")
  startedAt         DateTime @default(now())
  lastUpdate        DateTime @updatedAt
}