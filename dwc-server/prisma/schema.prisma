datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

// Raw telemetry from ESP32 Sensor Node
model telemetryLog {
  id                 Int      @id @default(autoincrement())
  potId              String   @default("A")
  rawPH              Int
  rawEC              Int
  realPH             Float
  realEC             Float
  isTankEmpty        Boolean
  isTankOverflowing  Boolean
  timestamp          DateTime @default(now())
}

// Persistent cultivation cycle state
model SystemState {
  id               Int      @id @default(1)
  currentStrain    String   @default("auto_kush")      // key for recipe
  currentProfilePath String @default("./recipes/default.json")
  cycleStartDate   DateTime @default(now())
  currentDay       Int      @default(1)
  automationMode   String   @default("AUTOMATED")      // or "MANUAL_OVERRIDE"
  lastDoseTime     DateTime?
  sysVol           Float    @default(18.0)             // actual reservoir liters
}

// Every successful or blocked dose (watchdog uses this)
model doseLog {
  id        Int      @id @default(autoincrement())
  potId     String   @default("A")
  pumpName  String
  ml        Float
  status    String
  timestamp DateTime @default(now())
}

// Watchdog configuration per pump
model WatchdogConfig {
  id            Int      @id @default(autoincrement())
  pumpName      String   @unique
  dailyLimitMl  Float    @default(15.0)
  cooldownSecs  Int      @default(30)
  enabled       Boolean  @default(true)
  updatedAt     DateTime @updatedAt
}

model BatchState {
  id                Int      @id @default(autoincrement())
  active            Boolean  @default(false)
  batchType         String   // "DILUTION", "NUTRIENT", "PH_CORRECTION", "EMERGENCY_WATER"
  totalWaterMl      Float
  confirmedWaterMl  Float    @default(0)
  totalNutrients    String?  // JSON string (e.g., {"cal":0,"micro":0,...})
  confirmedNutrients String? // JSON string
  targetPot         String?  @default("A")
  startedAt         DateTime @default(now())
  lastUpdate        DateTime @updatedAt
}